#!/usr/bin/env bash
# ストーリー動画ラッパー（薄い）。story_editor.py / Studio / remotion render を
# 覚えやすい名前で叩くだけ。本編用 ./run のストーリー版。
# 使い方:
#   ./run-story <コマンド> [引数]   … 直接実行
#   ./run-story                     … 番号メニュー（引数なし）
#   ./run-story help                … 一覧
# Python/JS側は無改変。RUN_DRY=1 を付けると実行せずコマンドだけ表示（確認用）。
#
# 台本編集・シーン/表情/ポーズ編集・台本生成・音(BGM/SE)設定・音声生成・書き出しは
# すべて `./run-story story` の中(タブ切替)で完結する。CLIコマンドは
# 「ブラウザを開かずに済ませたい/確認したい」補助操作だけを残している。
set -euo pipefail
cd "$(dirname "$0")"

PY="$(command -v python3 || command -v python || echo python3)"
STORY="story-01"                         # 台本/音声のファイル名ベース（public/<STORY>.json / .wav）

# コマンド表示して実行（RUN_DRY=1 なら表示のみ）。
run() { echo "▶ $*"; [ "${RUN_DRY:-}" = "1" ] || eval "$*"; }

# 全角数字→半角（スマホ入力対策）。
z2h() {
  local s="$1"
  s="${s//０/0}"; s="${s//１/1}"; s="${s//２/2}"; s="${s//３/3}"; s="${s//４/4}"
  s="${s//５/5}"; s="${s//６/6}"; s="${s//７/7}"; s="${s//８/8}"; s="${s//９/9}"
  printf '%s' "$s"
}

# ストーリーエディタ（台本編集・シーン/表情/ポーズ・台本生成・音・音声生成・書き出しをすべて内包）。
cmd_story() { run "$PY story_editor.py"; }

# ストーリーエディタを 0.0.0.0 で起動（Tailscale経由でスマホから開くレビュー用）。
cmd_story_ts() { run "$PY story_editor.py --host 0.0.0.0"; }

# Studioで全体プレビュー(HMR)。エディタのPlayterより高精細に確認したい時用。
cmd_dev() { run "cd video && npm run dev:story"; }

# 全体を書き出し → video/out/<タイトル>.mp4（エディタの書き出しボタンと同じ命名）。
cmd_render() {
  local filename
  filename="$($PY -c "import story_editor as s; print(s._safe_export_filename(s._load_story().get('title','')))")"
  run "cd video && npm run prep:story && npx remotion render StoryVideo \"out/${filename}\""
}

# 1フレームだけ静止画書き出し（確認用）。$1=フレーム番号（既定0）。
cmd_still() {
  local f="${1:-0}"
  run "cd video && npx remotion still StoryVideo out/still-${f}.png --frame=${f}"
}

# 音声だけCLIで再生成（VOICEVOX）＋ start/end/sentences を JSON に書き戻し。
# エディタの「🔊 音声生成」ボタンと同じ処理。ブラウザを開かずに済ませたい時用。
cmd_audio() {
  echo "※ VOICEVOX エンジンを起動しておくこと（http://localhost:50021）"
  run "$PY make_story_audio.py ${STORY}"
}

# assets/ → public/ を同期（背景/BGM/SE/立ち絵/manifest）。
# story_editor.py 起動時に自動実行されるため、通常は不要（素材反映がおかしい時の手動フォールバック）。
cmd_prep() { run "cd video && node scripts/prep-story.mjs"; }

# ストーリーエディタ用 Remotion Player を esbuild でビルド。
# story_editor.py 起動時に自動実行されるため、通常は不要（プレビューが古いままの時の手動フォールバック）。
cmd_player_build() { run "cd video && node scripts/build-story-player.mjs"; }

cmd_help() {
  cat <<'EOF'
ストーリー動画ラッパー  ./run-story <コマンド> [引数]   （引数なしでメニュー）

  story         ストーリーエディタ起動（台本編集・シーン/表情/ポーズ・台本生成・音・音声生成・書き出し）
  review-ts     エディタを0.0.0.0で起動（Tailscale経由でスマホから開くレビュー用）
  dev           Studioで全体プレビュー(HMR)
  render        全体を書き出し → video/out/<タイトル>.mp4
  still [N]     1フレームだけ静止画 → video/out/still-N.png（確認用）
  audio         音声だけCLIで再生成(VOICEVOX)＋実尺をJSONに書き戻し（ブラウザ不要な時用）
  prep          手動フォールバック: assets→public 同期（通常はstory起動時に自動実行）
  player-build  手動フォールバック: エディタ用Playerビルド（通常はstory起動時に自動実行）
  help          この一覧

基本の流れ:            ./run-story story で編集・音声生成 →（必要なら dev で確認）→ render
スマホから編集/レビュー: ./run-story review-ts
EOF
}

# 引数あり → 直接実行
if [ $# -gt 0 ]; then
  case "$1" in
    story)         cmd_story ;;
    review-ts)     cmd_story_ts ;;
    dev)           cmd_dev ;;
    render)        cmd_render ;;
    still)         cmd_still "$(z2h "${2:-0}")" ;;
    audio)         cmd_audio ;;
    prep)          cmd_prep ;;
    player-build)  cmd_player_build ;;
    help|-h|--help) cmd_help ;;
    *) echo "不明なコマンド: $1"; echo; cmd_help; exit 1 ;;
  esac
  exit 0
fi

# 引数なし → 番号メニュー
echo "=== ストーリー動画メニュー === (${STORY})"
echo "  1) story         ストーリーエディタ（台本編集・シーン/表情/ポーズ・台本生成・音・音声生成・書き出し）"
echo "  2) review-ts     エディタを0.0.0.0で起動（Tailscaleでスマホから）"
echo "  3) dev           Studioで全体プレビュー(HMR)"
echo "  4) render        全体を書き出し → video/out/<タイトル>.mp4"
echo "  5) still         1フレーム静止画（フレーム番号を聞く）"
echo "  6) audio         音声だけCLIで再生成（ブラウザ不要な時用）"
echo "  7) prep          手動フォールバック: assets→public 同期"
echo "  8) player-build  手動フォールバック: エディタ用Playerビルド"
echo "  0) help"
read -rp "番号: " n
n="$(z2h "$n")"
case "$n" in
  1) cmd_story ;;
  2) cmd_story_ts ;;
  3) cmd_dev ;;
  4) cmd_render ;;
  5) read -rp "フレーム番号: " f; cmd_still "$(z2h "$f")" ;;
  6) cmd_audio ;;
  7) cmd_prep ;;
  8) cmd_player_build ;;
  0|*) cmd_help ;;
esac
