#!/usr/bin/env bash
# 制作ラッパー（薄い）。main_story.py / review_server.py / npm render を覚えやすい名前で叩くだけ。
# 使い方:
#   ./run <コマンド> [引数]   … 直接実行
#   ./run                     … 番号メニュー（引数なし）
#   ./run help                … 一覧
# Python側は無改変。RUN_DRY=1 を付けると実行せずコマンドだけ表示（確認用）。
set -euo pipefail
cd "$(dirname "$0")"

PY="$(command -v python3 || command -v python || echo python3)"
STORIES="docs/stories"
STORY="docs/story"       # 常にアクティブプロジェクトへのシムリンクを指す
META="$STORY/meta.json"
FPS=30

# アクティブプロジェクト名（シムリンクのターゲット末尾）
active_project() {
  [ -L "$STORY" ] && basename "$(readlink "$STORY")" || echo "(legacy)"
}

# コマンド表示して実行（RUN_DRY=1 なら表示のみ）。
run() { echo "▶ $*"; [ "${RUN_DRY:-}" = "1" ] || eval "$*"; }

# 全角数字/カンマを半角へ（スマホ入力対策）。bashの文字列置換でlocale非依存に処理。
z2h() {
  local s="$1"
  s="${s//０/0}"; s="${s//１/1}"; s="${s//２/2}"; s="${s//３/3}"; s="${s//４/4}"
  s="${s//５/5}"; s="${s//６/6}"; s="${s//７/7}"; s="${s//８/8}"; s="${s//９/9}"
  s="${s//，/,}"; s="${s//、/,}"
  printf '%s' "$s"
}

short_dir() {  # slug → docs/shorts/<slug>（存在チェック）
  local d="docs/shorts/$1"
  [ -d "$d" ] || { echo "× $d がありません（先に shorts で生成）" >&2; exit 1; }
  echo "$d"
}

# meta.json の章一覧（番号/section/フレーム範囲/タイトル）を表示。0=導入 が分かるように。
cmd_chapters() {
  [ -f "$META" ] || { echo "× $META がありません（先に audio を実行）" >&2; return 1; }
  "$PY" - "$META" "$FPS" <<'PY'
import json, sys, math
meta, fps = sys.argv[1], int(sys.argv[2])
d = json.load(open(meta))
rng = {}
for t in d.get("topics", []):
    c = t.get("chapter")
    if c is None: continue
    r = rng.setdefault(c, [t.get("start", 0), t.get("end", 0), t.get("section", ""), t.get("title", "")])
    r[0] = min(r[0], t.get("start", 0)); r[1] = max(r[1], t.get("end", 0))
lab = {"intro": "導入", "trivia": "本編", "outro": "締め"}
print(" 章  種別  フレーム          秒          タイトル")
for c in sorted(rng):
    s, e, sec, ttl = rng[c]
    print(f"{c:>3}  {lab.get(sec, sec):<4} {int(s*fps)}-{math.ceil(e*fps):<9} {s:.0f}-{e:.0f}s   {ttl}")
PY
}

# 章番号 → meta.json から「開始フレーム 終了フレーム 開始秒 終了秒」を計算して出力。
# dev/render の章単位プレビュー/書き出しで共用（要 audio 済み＝meta.json存在）。
chap_range() {  # $1=章番号
  [ -f "$META" ] || { echo "× $META がありません（先に audio を実行）" >&2; return 1; }
  "$PY" - "$META" "$1" "$FPS" <<'PY'
import json, sys, math
meta, ch, fps = sys.argv[1], int(sys.argv[2]), int(sys.argv[3])
d = json.load(open(meta))
tops = [t for t in d.get("topics", []) if t.get("chapter") == ch]
if not tops:
    sys.exit(f"× 章 {ch} が meta.json に見つかりません（章番号を確認）")
s = min(t.get("start", 0) for t in tops)
e = max(t.get("end", 0) for t in tops)
print(f"{int(s*fps)} {math.ceil(e*fps)} {s:.1f} {e:.1f}")
PY
}

cmd_help() {
  cat <<'EOF'
制作ラッパー  ./run <コマンド> [引数]   （引数なしでメニュー）

[本編]
  script            台本＋画像を生成して停止（Gemini新規生成・レビュー待ち）
  images            既存の台本(script.json)のまま画像だけ取得（Gemini不使用・台本を上書きしない）
  review            レビュー画面を開く（/story・/shorts）
  review-ts         Tailscale経由でスマホから開けるレビュー画面（0.0.0.0待受）
  audio             音声＋meta を生成（VOICEVOX・全体で1回）
  meta              画像/見出しだけ直した時：音声据置で meta だけ再生成（全体）
  dev [章]          Remotion Studio（HMRプレビュー）。章番号を付けると横1章プレビュー(DialogueChapter)を起動
  render [章]       本編(横16:9)を書き出し → out/video.mp4。章番号を付けるとその章だけ out/ch<N>.mp4
  build             音声＋meta → 書き出し を一気に（レビュー後の本番出力）
  chapters          章一覧（番号/種別/フレーム/タイトル）を表示。0=導入 1..=本編 末尾=締め

  ※ dev/render の章単位は audio 済み（meta.json）が前提。audio/meta は全体で1回流す。

[ショート]  ※ slug = docs/shorts/<slug>
  shorts 1,2        本編ネタをまとめてショート化（Gemini1回）
  s-audio <slug>    ショートの音声＋meta
  depth  <slug>     ショートの深度生成（パララックス・任意）
  s-render <slug>   ショートを書き出し → video/out/short.mp4
  s-build <slug>    s-audio → depth → s-render を一気に

  help              この一覧

[プロジェクト管理]
  projects          保存済みプロジェクト一覧（★=アクティブ）
  new [name]        新しいプロジェクトを作成してアクティブに切り替え
  switch [name]     別のプロジェクトに切り替え
EOF
}

# ---- コマンド本体 ----
cmd_script()  { run "$PY main_story.py --stop-after-images"; }
cmd_images()  { run "$PY main_story.py --from-script $STORY/script.json --stop-after-images"; }  # 既存台本のまま画像取得
cmd_review()  { run "cd video && npm run build:review-player && cd .. && $PY review_server.py --dir $STORY"; }
cmd_review_ts(){ run "cd video && npm run build:review-player && cd .. && $PY review_server.py --dir $STORY --host 0.0.0.0"; }
cmd_audio()   { run "$PY main_story.py --from-script $STORY/script.json --images-from-dir"; }
cmd_meta()    { run "$PY main_story.py --from-script $STORY/script.json --meta-only"; }
cmd_dev()     {   # Studio（HMRプレビュー）。章番号を渡すと横1章プレビュー(DialogueChapter)を章クリップで起動。
  local ch="${1:-}"
  if [ -n "$ch" ]; then
    ch="$(z2h "$ch")"
    chap_range "$ch" >/dev/null || exit 1   # 章の存在チェック（無ければエラーで停止）
    echo "▶ 章${ch} を横プレビュー。Studio左の 'DialogueChapter' を開いてね（章${ch}にクリップ済み・HMR反復可）。"
    echo "  ※別の章に変えるなら props欄の clipChapter を編集 or ./run dev <別の章> で再起動。"
    run "cd video && REMOTION_CHAPTER=${ch} npm run dev"
  else
    run "cd video && npm run dev"
  fi
}
cmd_render()  {   # 書き出し。章番号を渡すとその章だけ video/out/ch<N>.mp4 に書き出す（--frames）。
  local ch="${1:-}"
  if [ -n "$ch" ]; then
    ch="$(z2h "$ch")"; local r; r="$(chap_range "$ch")" || exit 1
    set -- $r  # sf ef ss ee
    run "cd video && npm run prep && npx remotion render DialogueVideo out/ch${ch}.mp4 --frames=${1}-${2}"
  else
    run "cd video && npm run render"
  fi
}
cmd_build()   { cmd_audio; cmd_render; }  # 音声+meta → 書き出し（本編の本番出力を一気に）

cmd_shorts()  {
  local list="${1:-}"
  [ -n "$list" ] || { read -rp "ショート化するネタ番号（例 1,2）: " list; }
  list="$(z2h "$list")"
  run "$PY main_story.py --from-script $STORY/script.json --shorts-from \"$list\""
}
cmd_s_audio() { local d; d="$(short_dir "$1")"; run "$PY main_story.py --from-script $d/script.json --images-from-dir --output-dir $d"; }
cmd_depth()   { local d; d="$(short_dir "$1")"; run "$PY make_depth.py --dir $d"; }
cmd_s_render(){ local d; d="$(short_dir "$1")"; run "cd video && SRC_DIR=../$d npm run render:short"; }
cmd_s_build() { cmd_s_audio "$1"; cmd_depth "$1"; cmd_s_render "$1"; }

# ---- プロジェクト管理 ----
cmd_projects() {
  local active; active="$(active_project)"
  echo "保存済みプロジェクト（★=アクティブ）:"
  if [ -d "$STORIES" ]; then
    for d in "$STORIES"/*/; do
      [ -d "$d" ] || continue
      local name; name="$(basename "$d")"
      [ "$name" = "$active" ] && echo "  ★ $name" || echo "    $name"
    done
  else
    echo "  (なし)"
  fi
}

cmd_switch() {  # $1=name
  local name=""
  if [ -n "${1-}" ]; then
    name="$1"
  else
    cmd_projects
    read -rp "切り替え先プロジェクト名: " name || name=""
  fi
  [ -n "$name" ] || { echo "× 名前が入力されませんでした" >&2; exit 1; }
  local target="$STORIES/$name"
  [ -d "$target" ] || { echo "× $target が存在しません（./run projects で一覧確認）" >&2; exit 1; }
  ln -sfn "stories/$name" "$STORY"
  echo "✓ アクティブ → $name"
}

cmd_new() {  # $1=name
  local name=""
  if [ -n "${1-}" ]; then
    name="$1"
  else
    read -rp "新しいプロジェクト名（例: tokyo-tower）: " name || name=""
  fi
  [ -n "$name" ] || { echo "× 名前が入力されませんでした" >&2; exit 1; }
  local target="$STORIES/$name"
  [ ! -d "$target" ] || { echo "× $target は既に存在します" >&2; exit 1; }
  mkdir -p "$target"
  [ -f "config/config.story.yaml" ] && cp "config/config.story.yaml" "$target/config.story.yaml"
  ln -sfn "stories/$name" "$STORY"
  echo "✓ 新規プロジェクト作成: $name（アクティブに設定済み）"
  echo "  次: ./run script でスクリプト生成"
}

# 引数あり → 直接実行
if [ $# -gt 0 ]; then
  case "$1" in
    script)   cmd_script ;;
    images)   cmd_images ;;
    review)   cmd_review ;;
    review-ts) cmd_review_ts ;;
    audio)    cmd_audio ;;
    meta)     cmd_meta ;;
    dev)      cmd_dev "${2:-}" ;;
    render)   cmd_render "${2:-}" ;;
    build)    cmd_build ;;
    chapters|list) cmd_chapters ;;
    shorts)   cmd_shorts "${2:-}" ;;
    s-audio)  cmd_s_audio "${2:?slug を指定}" ;;
    depth)    cmd_depth "${2:?slug を指定}" ;;
    s-render) cmd_s_render "${2:?slug を指定}" ;;
    s-build)  cmd_s_build "${2:?slug を指定}" ;;
    projects) cmd_projects ;;
    new)      cmd_new "${2:-}" ;;
    switch)   cmd_switch "${2:-}" ;;
    help|-h|--help) cmd_help ;;
    *) echo "不明なコマンド: $1"; echo; cmd_help; exit 1 ;;
  esac
  exit 0
fi

# 引数なし → 番号メニュー
echo "=== 制作メニュー === (プロジェクト: $(active_project))"
echo "[本編]"
echo "  1) script    台本+画像生成 → レビュー待ち（Gemini新規）"
echo "  2) images    既存台本のまま画像だけ取得（上書きしない）"
echo "  3) review    レビュー画面"
echo "  3t) review-ts Tailscale経由でスマホから開くレビュー画面"
echo "  4) audio     音声+meta（セリフを変えた時）"
echo "  5) meta      metaだけ再生成（画像/見出しだけ直した時・音声据置）"
echo "  6) dev       Studioで全体プレビュー(HMR)"
echo "  7) render    全体を書き出し"
echo "  8) build     音声+meta+書き出し（本番出力）"
echo "[章単位]  ※先に audio（meta.json）が必要。0=導入 1..=本編 末尾=締め"
echo "  9) chapters   章一覧を表示（番号/種別/フレーム/タイトル）"
echo " 10) dev 章     横1章プレビュー(DialogueChapter)を起動（章一覧→章番号を聞く）"
echo " 11) render 章  章だけ書き出し → out/ch<N>.mp4（章一覧→章番号を聞く）"
echo "[ショート]"
echo " 12) shorts    一括生成"
echo " 13) s-audio   音声+meta"
echo " 14) depth     深度（パララックス）"
echo " 15) s-render  書き出し"
echo " 16) s-build   音声+meta+深度+書き出し"
echo "[プロジェクト管理]"
echo " 17) projects  保存済みプロジェクト一覧"
echo " 18) new       新規プロジェクト作成"
echo " 19) switch    プロジェクト切り替え"
echo "  0) help"
read -rp "番号: " n
n="$(z2h "$n")"
case "$n" in
  1) cmd_script ;;
  2) cmd_images ;;
  3) cmd_review ;;
  4) cmd_audio ;;
  5) cmd_meta ;;
  6) cmd_dev ;;
  7) cmd_render ;;
  8) cmd_build ;;
  9) cmd_chapters || true ;;
  10) cmd_chapters || true; read -rp "章番号: " c; cmd_dev "$(z2h "$c")" ;;
  11) cmd_chapters || true; read -rp "章番号: " c; cmd_render "$(z2h "$c")" ;;
  12) cmd_shorts "" ;;
  13) read -rp "slug: " s; cmd_s_audio "$s" ;;
  14) read -rp "slug: " s; cmd_depth "$s" ;;
  15) read -rp "slug: " s; cmd_s_render "$s" ;;
  16) read -rp "slug: " s; cmd_s_build "$s" ;;
  17) cmd_projects ;;
  18) cmd_new "" ;;
  19) cmd_switch "" ;;
  0|*) cmd_help ;;
esac
