{
  "name": "video",
  "private": true,
  "version": "1.0.0",
  "description": "meta.json + digest.mp3 から掛け合い動画を生成するRemotionプロジェクト（ローカル描画）",
  "type": "module",
  "scripts": {
    "prep": "node scripts/prep.mjs",
    "build:review-player": "node scripts/build-review-player.mjs",
    "parts": "node scripts/make-avatar-parts.mjs",
    "psd:preview": "node scripts/psd-export.mjs preview",
    "psd:build": "node scripts/psd-export.mjs build",
    "dev": "npm run prep && remotion studio",
    "prep:story": "node scripts/prep-story.mjs",
    "dev:story": "npm run prep:story && remotion studio",
    "render:story": "npm run prep:story && remotion render StoryVideo out/story.mp4",
    "render": "npm run prep && remotion render DialogueVideo out/video.mp4",
    "render:short": "npm run prep && remotion render DialogueVideoShort out/short.mp4",
    "compositions": "remotion compositions",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/media-utils": "^4.0.0",
    "@remotion/player": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.7",
    "ag-psd": "^30.1.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0"
  }
}
