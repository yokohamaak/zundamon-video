# これを .env にコピーして値を記入する（.env は .gitignore 済・コミット禁止）。
# 無料枠/ローカルのみ使用。従量課金APIは使わない。

# Gemini 台本生成（必須）。Google AI Studio の APIキー。
GEMINI_API_KEY=

# 画像取得（Phase2・無料登録のキー）。Phase0-1 では未使用。
PEXELS_API_KEY=
PIXABAY_API_KEY=

# VOICEVOX 接続先。Mac直実行なら既定の localhost:50021 でよい（未設定可）。
# コンテナから叩く場合のみ http://host.docker.internal:50021 に上書き。
# VOICEVOX_URL=http://localhost:50021
